# Destination credentials. dlt reads these env vars directly — no code changes
# needed. Logical connection names in pipelines/*.yml resolve to one of these.
#
# Copy this file to `.env` (gitignored) and fill in real values, OR set them in
# your shell / container environment / secrets backend.

# Postgres destination — full DSN form:
DESTINATION__POSTGRES__CREDENTIALS=postgresql://user:password@host:5432/dbname

# Snowflake destination — dlt section form. Key-pair auth: base64-encode the
# private key or mount a key file and reference it here.
DESTINATION__SNOWFLAKE__CREDENTIALS__HOST=
DESTINATION__SNOWFLAKE__CREDENTIALS__USERNAME=
DESTINATION__SNOWFLAKE__CREDENTIALS__PASSWORD=
DESTINATION__SNOWFLAKE__CREDENTIALS__DATABASE=
DESTINATION__SNOWFLAKE__CREDENTIALS__WAREHOUSE=
DESTINATION__SNOWFLAKE__CREDENTIALS__ROLE=

# Databricks destination — host + http_path + token, plus staging-location
# credentials (S3 / ADLS volume) configured separately.
DESTINATION__DATABRICKS__CREDENTIALS__SERVER_HOSTNAME=
DESTINATION__DATABRICKS__CREDENTIALS__HTTP_PATH=
DESTINATION__DATABRICKS__CREDENTIALS__ACCESS_TOKEN=
DESTINATION__DATABRICKS__CREDENTIALS__CATALOG=

# Source credentials follow the same pattern, scoped by logical connection name.
# Concrete example for the Segment 5 Postgres -> Postgres pipeline:
SOURCES__SQL_DATABASE__PG_SOURCE__CREDENTIALS=postgresql://user:password@postgres-source:5432/source_db
# REST API token example (used by future Segment-3+ pipelines):
# SOURCES__REST_API__GITHUB__TOKEN=...

# Destinations may also be scoped by logical connection name. dlt resolves
# DESTINATION__<CONNECTION>__CREDENTIALS first, then falls back to
# DESTINATION__<TYPE>__CREDENTIALS above. Use the scoped form when one env
# hosts multiple Postgres warehouses.
DESTINATION__PG_WAREHOUSE__CREDENTIALS=postgresql://user:password@postgres-destination:5432/warehouse_db

# Airflow home (where airflow.cfg + metadata DB + logs live locally).
AIRFLOW_HOME=./airflow_home
# Local executor; flip to KubernetesExecutor in prod (Segment 10).
AIRFLOW__CORE__EXECUTOR=LocalExecutor
# Point Airflow's metadata DB at the persistent postgres-airflow service in
# docker-compose (Segment 6). Defaults to a local SQLite file otherwise.
# AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres-airflow:5432/airflow
