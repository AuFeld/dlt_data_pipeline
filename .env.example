# Destination credentials. dlt reads these env vars directly — no code changes
# needed. Logical connection names in pipelines/*.yml resolve to one of these.
#
# Copy this file to `.env` (gitignored) and fill in real values, OR set them in
# your shell / container environment / secrets backend.

# Destinations are keyed by the logical connection name from pipelines/*.yml
# (no type segment). dlt resolves DESTINATION__<CONNECTION>__CREDENTIALS
# because destinations/factory.py constructs each destination with
# destination_name=connection. Names below match the committed example YAMLs.

# Postgres destination (connection: pg_warehouse) — full DSN form:
DESTINATION__PG_WAREHOUSE__CREDENTIALS=postgresql://user:password@host:5432/dbname

# Snowflake destination (connection: snowflake_warehouse) — dlt section form.
# Key-pair auth: set credentials.private_key (base64-encoded PEM) and
# credentials.private_key_passphrase in .dlt/secrets.toml under
# [destination.snowflake_warehouse.credentials] instead of the password env var.
DESTINATION__SNOWFLAKE_WAREHOUSE__CREDENTIALS__HOST=
DESTINATION__SNOWFLAKE_WAREHOUSE__CREDENTIALS__USERNAME=
DESTINATION__SNOWFLAKE_WAREHOUSE__CREDENTIALS__PASSWORD=
DESTINATION__SNOWFLAKE_WAREHOUSE__CREDENTIALS__DATABASE=
DESTINATION__SNOWFLAKE_WAREHOUSE__CREDENTIALS__WAREHOUSE=
DESTINATION__SNOWFLAKE_WAREHOUSE__CREDENTIALS__ROLE=

# Databricks destination (connection: dbx_warehouse) — NOT in active use.
# Stubbed in destinations/factory.py; current architecture loads Snowflake and
# Databricks consumes via External Data. Keys included for completeness only.
DESTINATION__DBX_WAREHOUSE__CREDENTIALS__SERVER_HOSTNAME=
DESTINATION__DBX_WAREHOUSE__CREDENTIALS__HTTP_PATH=
DESTINATION__DBX_WAREHOUSE__CREDENTIALS__ACCESS_TOKEN=
DESTINATION__DBX_WAREHOUSE__CREDENTIALS__CATALOG=

# Source credentials follow the same pattern, scoped by logical connection name.
# Concrete example for the Segment 5 Postgres -> Postgres pipeline. The user /
# password / hostname here match docker/docker-compose.yml's `postgres-source`
# service (POSTGRES_USER=source, POSTGRES_PASSWORD=source, POSTGRES_DB=source_db).
SOURCES__SQL_DATABASE__PG_SOURCE__CREDENTIALS=postgresql://source:source@postgres-source:5432/source_db
# Segment 7 — pg_cdc reuses the same source DB but addresses it under its
# own (TYPE, CONNECTION) coordinate. Same credentials work; the dedicated
# `replicator` role (created by docker/postgres-source-init/01_replication.sql)
# is a least-privilege alternative for prod (REPLICATION + pg_read_all_data).
SOURCES__PG_CDC__PG_SOURCE__CREDENTIALS=postgresql://source:source@postgres-source:5432/source_db
# REST API token example (used by future Segment-3+ pipelines):
# SOURCES__REST_API__GITHUB__TOKEN=...

# DESTINATION__PG_WAREHOUSE__CREDENTIALS above resolves the `pg_warehouse`
# destination. In docker compose it points at the `postgres-destination` service
# (POSTGRES_USER=warehouse, POSTGRES_PASSWORD=warehouse, POSTGRES_DB=warehouse_db):
#   DESTINATION__PG_WAREHOUSE__CREDENTIALS=postgresql://warehouse:warehouse@postgres-destination:5432/warehouse_db

# ─── Docker compose (used by docker/docker-compose.yml) ────────────────────
# The hostnames below resolve only inside the compose network. For host-shell
# use (e.g. running `python -m dlt_data_pipeline run …` outside docker),
# substitute `localhost:5433` (source) / `localhost:5434` (destination) /
# leave the metadata DSN unset (host-mode `airflow standalone` uses sqlite).

# Airflow home (where airflow.cfg + metadata DB + logs live locally).
AIRFLOW_HOME=./airflow_home
# LocalExecutor inside compose; KubernetesExecutor in prod (Segment 10).
# Host-mode `airflow standalone` from Segment 4 keeps SequentialExecutor via
# airflow_home/airflow.cfg — this env var only kicks in when set.
AIRFLOW__CORE__EXECUTOR=LocalExecutor
# Metadata DB. LocalExecutor refuses sqlite, so compose must set this.
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres-airflow:5432/airflow
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# scripts/seed_local.sh auto-populates this on first run if left blank.
AIRFLOW__CORE__FERNET_KEY=
# uid:gid the airflow container runs as. macOS Docker Desktop reverse-maps
# uids so 50000 works out of the box. On Linux hosts with a non-50000 uid
# touching bind-mounted dirs, set to your `id -u` and re-create the stack.
AIRFLOW_UID=50000
