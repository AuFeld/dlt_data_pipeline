{
  "$defs": {
    "AlertSeverity": {
      "enum": [
        "P1",
        "P2",
        "info"
      ],
      "title": "AlertSeverity",
      "type": "string"
    },
    "AlertsConfig": {
      "additionalProperties": false,
      "description": "Per-pipeline alert routing knobs.\n\nWebhook URL, default channels per severity, and SMTP credentials are\ndeployment concerns and live in env vars (see ``observability.alerts``\nmodule docstring). YAML carries only per-pipeline overrides.",
      "properties": {
        "dedup_window_minutes": {
          "default": 15,
          "maximum": 1440,
          "minimum": 0,
          "title": "Dedup Window Minutes",
          "type": "integer"
        },
        "email_recipients": {
          "items": {
            "type": "string"
          },
          "title": "Email Recipients",
          "type": "array"
        },
        "on_schema_change": {
          "default": true,
          "title": "On Schema Change",
          "type": "boolean"
        },
        "on_sla_miss": {
          "default": true,
          "title": "On Sla Miss",
          "type": "boolean"
        },
        "severity": {
          "$ref": "#/$defs/AlertSeverity",
          "default": "P2"
        },
        "slack_channel": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Slack Channel"
        }
      },
      "title": "AlertsConfig",
      "type": "object"
    },
    "BackfillConfig": {
      "additionalProperties": false,
      "description": "Chunked, resumable historical load knobs (Segment 12).\n\n``chunk_size`` is an ISO-8601 duration string parsed by ``isodate``\n(e.g. ``P1D`` = one day, ``PT6H`` = six hours). ``partition_field``\ndefaults to ``sync.cursor_field`` when omitted.",
      "properties": {
        "chunk_size": {
          "title": "Chunk Size",
          "type": "string"
        },
        "partition_field": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Partition Field"
        }
      },
      "required": [
        "chunk_size"
      ],
      "title": "BackfillConfig",
      "type": "object"
    },
    "DestinationConfig": {
      "additionalProperties": false,
      "properties": {
        "connection": {
          "title": "Connection",
          "type": "string"
        },
        "dataset": {
          "title": "Dataset",
          "type": "string"
        },
        "type": {
          "$ref": "#/$defs/DestinationType"
        }
      },
      "required": [
        "type",
        "connection",
        "dataset"
      ],
      "title": "DestinationConfig",
      "type": "object"
    },
    "DestinationType": {
      "enum": [
        "postgres",
        "snowflake",
        "databricks",
        "duckdb"
      ],
      "title": "DestinationType",
      "type": "string"
    },
    "OptionsConfig": {
      "additionalProperties": false,
      "properties": {
        "schema_contract": {
          "$ref": "#/$defs/SchemaContract",
          "default": "evolve"
        },
        "write_disposition": {
          "$ref": "#/$defs/WriteDisposition",
          "default": "append"
        }
      },
      "title": "OptionsConfig",
      "type": "object"
    },
    "QualityCheckMode": {
      "enum": [
        "same_cluster",
        "cross_cluster"
      ],
      "title": "QualityCheckMode",
      "type": "string"
    },
    "QualityConfig": {
      "additionalProperties": false,
      "description": "Data-quality knobs (Segment 12, v1 scope).\n\n``row_count_check`` runs source-vs-destination reconciliation per replicated\ntable. ``check_mode`` selects whether to use one SQL connection that can\nreach both (``same_cluster``) or two PythonOperator-driven probes\n(``cross_cluster``, default \u2014 no Airflow Connection wiring required).",
      "properties": {
        "check_mode": {
          "$ref": "#/$defs/QualityCheckMode",
          "default": "cross_cluster"
        },
        "row_count_check": {
          "default": false,
          "title": "Row Count Check",
          "type": "boolean"
        }
      },
      "title": "QualityConfig",
      "type": "object"
    },
    "ResourcesConfig": {
      "additionalProperties": false,
      "description": "Optional pod resource requests/limits for KubernetesExecutor.\n\nLocalExecutor ignores these; KubernetesExecutor (Segment 10) consumes\nthem via ``executor_config={\"pod_override\": V1Pod(...)}`` on each task.\nUsed as both k8s requests AND limits (Guaranteed QoS).",
      "properties": {
        "cpu": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cpu"
        },
        "memory": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Memory"
        }
      },
      "title": "ResourcesConfig",
      "type": "object"
    },
    "ScheduleConfig": {
      "additionalProperties": false,
      "properties": {
        "cron": {
          "title": "Cron",
          "type": "string"
        },
        "enabled": {
          "default": true,
          "title": "Enabled",
          "type": "boolean"
        }
      },
      "required": [
        "cron"
      ],
      "title": "ScheduleConfig",
      "type": "object"
    },
    "SchemaContract": {
      "enum": [
        "evolve",
        "freeze",
        "discard_row"
      ],
      "title": "SchemaContract",
      "type": "string"
    },
    "SourceFilesystem": {
      "additionalProperties": false,
      "properties": {
        "config": {
          "additionalProperties": true,
          "title": "Config",
          "type": "object"
        },
        "connection": {
          "title": "Connection",
          "type": "string"
        },
        "type": {
          "const": "filesystem",
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "connection",
        "type"
      ],
      "title": "SourceFilesystem",
      "type": "object"
    },
    "SourcePgCdc": {
      "additionalProperties": false,
      "properties": {
        "config": {
          "additionalProperties": true,
          "title": "Config",
          "type": "object"
        },
        "connection": {
          "title": "Connection",
          "type": "string"
        },
        "type": {
          "const": "pg_cdc",
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "connection",
        "type"
      ],
      "title": "SourcePgCdc",
      "type": "object"
    },
    "SourceRestApi": {
      "additionalProperties": false,
      "properties": {
        "config": {
          "additionalProperties": true,
          "title": "Config",
          "type": "object"
        },
        "connection": {
          "title": "Connection",
          "type": "string"
        },
        "type": {
          "const": "rest_api",
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "connection",
        "type"
      ],
      "title": "SourceRestApi",
      "type": "object"
    },
    "SourceSqlDatabase": {
      "additionalProperties": false,
      "properties": {
        "config": {
          "additionalProperties": true,
          "title": "Config",
          "type": "object"
        },
        "connection": {
          "title": "Connection",
          "type": "string"
        },
        "type": {
          "const": "sql_database",
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "connection",
        "type"
      ],
      "title": "SourceSqlDatabase",
      "type": "object"
    },
    "SyncConfig": {
      "additionalProperties": false,
      "properties": {
        "backfill": {
          "anyOf": [
            {
              "$ref": "#/$defs/BackfillConfig"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "cursor_field": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cursor Field"
        },
        "lookback": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Lookback"
        },
        "mode": {
          "$ref": "#/$defs/SyncMode"
        },
        "primary_key": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Primary Key"
        },
        "tolerance_seconds": {
          "default": 0,
          "maximum": 86400,
          "minimum": 0,
          "title": "Tolerance Seconds",
          "type": "integer"
        }
      },
      "required": [
        "mode"
      ],
      "title": "SyncConfig",
      "type": "object"
    },
    "SyncMode": {
      "enum": [
        "full_refresh",
        "incremental",
        "cdc"
      ],
      "title": "SyncMode",
      "type": "string"
    },
    "WriteDisposition": {
      "enum": [
        "append",
        "replace",
        "merge"
      ],
      "title": "WriteDisposition",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "alerts": {
      "$ref": "#/$defs/AlertsConfig"
    },
    "destination": {
      "$ref": "#/$defs/DestinationConfig"
    },
    "name": {
      "title": "Name",
      "type": "string"
    },
    "options": {
      "$ref": "#/$defs/OptionsConfig"
    },
    "quality": {
      "$ref": "#/$defs/QualityConfig"
    },
    "resources": {
      "$ref": "#/$defs/ResourcesConfig"
    },
    "schedule": {
      "$ref": "#/$defs/ScheduleConfig"
    },
    "source": {
      "discriminator": {
        "mapping": {
          "filesystem": "#/$defs/SourceFilesystem",
          "pg_cdc": "#/$defs/SourcePgCdc",
          "rest_api": "#/$defs/SourceRestApi",
          "sql_database": "#/$defs/SourceSqlDatabase"
        },
        "propertyName": "type"
      },
      "oneOf": [
        {
          "$ref": "#/$defs/SourceRestApi"
        },
        {
          "$ref": "#/$defs/SourceSqlDatabase"
        },
        {
          "$ref": "#/$defs/SourceFilesystem"
        },
        {
          "$ref": "#/$defs/SourcePgCdc"
        }
      ],
      "title": "Source"
    },
    "sync": {
      "$ref": "#/$defs/SyncConfig"
    }
  },
  "required": [
    "name",
    "source",
    "sync",
    "destination",
    "schedule"
  ],
  "title": "PipelineConfig",
  "type": "object"
}
