# Copy to .dlt/secrets.toml (gitignored) and fill in real values.
# Logical connection names referenced from pipelines/*.yml resolve here.

# Example: destination Postgres
# [destination.postgres.credentials]
# database = "warehouse"
# username = "loader"
# password = ""
# host = "localhost"
# port = 5432

# Example: source SQL database connection named "pg_source"
# [sources.sql_database.pg_source.credentials]
# drivername = "postgresql"
# database = "app"
# username = "readonly"
# password = ""
# host = "localhost"
# port = 5432
